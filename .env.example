# --- Required ---
# 32+ char random string. Used for: JWT signing (HS256), AES-GCM key derivation
# (HKDF) for MFA secret-at-rest, HMAC for IP hashing.
ADMIN_SESSION_SECRET=replace-with-min-32-char-random-secret

# --- Optional ---
# Cloudflare Turnstile (https://developers.cloudflare.com/turnstile/)
# When unset, captcha checks are skipped (development convenience).
# TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key

# Operational notification target for new contact submissions.
# CONTACT_NOTIFY_EMAIL=ops@cybersystema.com

# --- Bootstrapping ---
# Admin users live in the D1 `admin_users` table — there are no static admin
# username/password env vars. Apply migrations and seed your first admin:
#   npm run db:apply:local
#   npm run seed-admin -- --username admin --password '...' --role super_admin
# (use --remote for production)

